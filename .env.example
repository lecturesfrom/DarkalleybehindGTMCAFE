# ─── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres connection string (find in Neon dashboard → Connection Details)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ─── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Production URL of the app (or http://localhost:3000 for local dev)
NEXTAUTH_URL=https://darkalleybehindgtmcafe.xyz

# ─── Slack App ─────────────────────────────────────────────────────────────────
# From api.slack.com/apps → your app → Basic Information + OAuth & Permissions

# OAuth credentials (Basic Information → App Credentials)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# For verifying incoming Slack requests (Basic Information → Signing Secret)
SLACK_SIGNING_SECRET=

# Bot User OAuth Token (OAuth & Permissions → Bot Token, starts with xoxb-)
SLACK_BOT_TOKEN=

# GTM Cafe workspace ID — Slack desktop → right-click workspace name → Copy Workspace ID
# Must start with T (e.g. T01234ABCDE)
SLACK_WORKSPACE_ID=
